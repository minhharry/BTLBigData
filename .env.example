# Postgres Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=app_database

# pgAdmin Configuration
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin_secret_password

# WQI Consumer Configuration
WQI_FLUSH_INTERVAL=10 minutes

# Host Paths (Optional: You can change where data is stored on your machine)
DATA_PATH=./data